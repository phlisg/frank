migrate:
  image: "frank-{{.ProjectName}}-laravel.test"
  volumes:
    - .:/var/www/html
  environment:
    - WWWUSER=${UID:-1000}
  env_file:
    - .env
  working_dir: /var/www/html
  restart: "no"
  networks:
    - frank
  healthcheck:
    disable: true
  labels:
    frank.project: "{{.ProjectName}}"
    frank.init: migrate
  command:
    - /bin/bash
    - -lc
    - |
      set -e
      if [ ! -d vendor ]; then
        echo "[frank.migrate] composer install"
        composer install --no-interaction --prefer-dist --no-progress
      fi
      if grep -q '^APP_KEY=$' .env 2>/dev/null; then
        echo "[frank.migrate] generating APP_KEY"
        php artisan key:generate --force --no-interaction
      fi
      echo "[frank.migrate] artisan migrate --force"
      php artisan migrate --force
