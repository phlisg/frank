schedule:
  tty: true
  image: "frank-{{.ProjectName}}-laravel.test"
  depends_on:
    laravel.test:
      condition: service_started
    migrate:
      condition: service_completed_successfully
  volumes:
    - .:/var/www/html
  environment:
    - WWWUSER=${UID:-1000}
  env_file:
    - .env
  working_dir: /var/www/html
  restart: unless-stopped
  # schedule:work is idempotent (no in-flight work). Skip docker's 10s grace
  # and SIGKILL immediately so `frank down` isn't blocked by the shutdown.
  stop_signal: SIGKILL
  networks:
    - frank
  healthcheck:
    disable: true
  labels:
    frank.project: "{{.ProjectName}}"
    frank.worker: declared
    frank.worker.type: schedule
  command:
    - php
    - artisan
    - schedule:work
