pgsql:
  image: "postgres:{{.Version}}"
  environment:
    POSTGRES_DB: "${DB_DATABASE}"
    POSTGRES_USER: "${DB_USERNAME}"
    POSTGRES_PASSWORD: "${DB_PASSWORD}"
  volumes:
    - pgsql_data:/var/lib/postgresql/data
    - .frank/scripts/create-testing-database.sql:/docker-entrypoint-initdb.d/10-create-testing-database.sql
  ports:
    - "{{.Port}}:5432"
  networks:
    - frank
  healthcheck:
    test: ["CMD-SHELL", "pg_isready -U ${DB_USERNAME:-sail}"]
    interval: 1s
    timeout: 3s
    retries: 30
    start_period: 30s
