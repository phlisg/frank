#!/bin/bash

echo ""
echo "# phlisg/frank shell helpers:"
echo ""
echo "activate() {"
echo "  if [ -f frank.yaml ] || [ -d .frank ]; then"
echo "    source <(just _activate)"
echo "  else"
echo "    echo \"Not in a Frank project (no frank.yaml found).\""
echo "  fi"
echo "}"
echo ""
echo "up() {"
echo "  just up && source <(just _activate)"
echo "}"
echo ""
echo "down() {"
echo "  just down"
echo "  if [ -n \"\$FRANK_ENV_ACTIVE\" ]; then"
echo "    deactivate"
echo "  fi"
echo "}"
echo ""
